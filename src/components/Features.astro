---
const features = [
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Thousands of channels',
    desc: 'Access 20,000+ live channels from around the world including sports, news, entertainment, and more.',
    key: 'f1',
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>',
    title: 'Multi-device support',
    desc: 'Watch on Smart TVs, phones, tablets, computers, and MAG boxes. Switch between devices seamlessly.',
    key: 'f2',
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: '99.9% uptime',
    desc: 'Reliable servers with automatic failover and intelligent routing ensure uninterrupted streaming.',
    key: 'f3',
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'Quick setup',
    desc: 'Get activated in minutes. Our team handles the technical setup so you can start watching right away.',
    key: 'f4',
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>',
    title: 'HD, 4K & 8K quality',
    desc: 'Stunning picture quality across all content. From HD to 8K, experience every detail.',
    key: 'f5',
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
    title: '14-day guarantee',
    desc: 'Not satisfied? Get a full refund within 14 days. No questions asked, no risk.',
    key: 'f6',
  },
];
---

<section id="features" class="section features-section">
  <div class="container">
    <div class="section-heading reveal">
      <div class="section-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v3m0 16v3M4.22 4.22l2.12 2.12m11.32 11.32l2.12 2.12M1 12h3m16 0h3M4.22 19.78l2.12-2.12m11.32-11.32l2.12-2.12"/></svg>
        <span data-i18n="features.label">Features</span>
      </div>
      <h2 class="section-title" data-i18n="features.title">Everything you need for premium entertainment</h2>
      <p class="section-subtitle" data-i18n="features.desc">
        We focus on quality, reliability, and simplicity so you can enjoy the best IPTV experience.
      </p>
    </div>
    <div class="features-grid">
      {features.map((f, i) => (
        <div class={`feature-card card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="feature-icon" set:html={f.icon} />
          <h3 class="feature-title" data-i18n={`features.${f.key}.title`}>{f.title}</h3>
          <p class="feature-desc" data-i18n={`features.${f.key}.desc`}>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--gray-50);
  }

  .section-heading {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--blue-500);
    background: rgba(37, 99, 235, 0.06);
    border: 1px solid rgba(37, 99, 235, 0.12);
    margin-bottom: 20px;
  }

  .section-heading .section-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .section-heading .section-subtitle {
    font-size: 1.1rem;
    color: var(--gray-500);
    margin-top: 14px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    padding: 32px 28px;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-sm);
    background: var(--blue-50);
    color: var(--blue-500);
    margin-bottom: 18px;
  }

  .feature-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .feature-desc {
    font-size: 0.9rem;
    color: var(--gray-500);
    line-height: 1.65;
  }

  @media (max-width: 868px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 568px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
