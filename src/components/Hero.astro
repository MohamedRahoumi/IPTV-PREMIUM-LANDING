<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 140px 0 80px;
    overflow: hidden;
  }

  .hero-bg-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% -20%, rgba(37, 99, 235, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 80% 80%, rgba(14, 165, 233, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    max-width: 540px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--blue-500);
    background: rgba(37, 99, 235, 0.06);
    border: 1px solid rgba(37, 99, 235, 0.12);
    margin-bottom: 28px;
  }

  .hero-title {
    font-size: clamp(2.4rem, 4.8vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    color: var(--gray-500);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 460px;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }

  .hero-trust {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .trust-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--gray-500);
    padding: 7px 13px;
    border-radius: var(--radius-full);
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    transition: var(--transition);
  }

  .trust-chip:hover {
    border-color: var(--gray-300);
    background: var(--white);
  }

  .trust-chip svg {
    color: var(--blue-500);
  }

  /* Dashboard Mockup */
  .hero-visual {
    position: relative;
  }

  .dashboard-mockup {
    background: var(--white);
    border-radius: var(--radius-xl);
    box-shadow: 0 25px 60px -16px rgba(0, 0, 0, 0.15), 0 4px 12px rgba(0, 0, 0, 0.04);
    border: 1px solid var(--gray-200);
    overflow: hidden;
    position: relative;
  }

  .mockup-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--gray-100);
    background: var(--gray-50);
  }

  .mockup-dots {
    display: flex;
    gap: 6px;
  }

  .mockup-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .mockup-dots span:nth-child(1) { background: #ef4444; }
  .mockup-dots span:nth-child(2) { background: #f59e0b; }
  .mockup-dots span:nth-child(3) { background: #22c55e; }

  .mockup-tabs {
    display: flex;
    gap: 2px;
    background: var(--gray-200);
    padding: 3px;
    border-radius: 8px;
  }

  .mockup-tabs .tab {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    color: var(--gray-500);
    cursor: default;
  }

  .mockup-tabs .tab.active {
    background: var(--white);
    color: var(--gray-900);
    box-shadow: var(--shadow-sm);
  }

  .mockup-user .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-500), var(--sky-500));
  }

  .mockup-body {
    display: grid;
    grid-template-columns: 60px 1fr;
    height: 300px;
  }

  .mockup-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 6px;
    background: var(--gray-50);
    border-right: 1px solid var(--gray-100);
  }

  .sidebar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 6px 4px;
    border-radius: 8px;
    cursor: default;
    transition: var(--transition);
  }

  .sidebar-item.active {
    background: var(--white);
    box-shadow: var(--shadow-sm);
  }

  .sidebar-item svg {
    width: 14px;
    height: 14px;
  }

  .sidebar-item span {
    font-size: 0.5rem;
    font-weight: 600;
    color: var(--gray-500);
    letter-spacing: 0.02em;
  }

  .sidebar-item.active span {
    color: var(--gray-900);
  }

  .mockup-main {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .main-player {
    background: linear-gradient(135deg, #1e293b, #0f172a);
    border-radius: var(--radius-md);
    height: 90px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 14px;
    overflow: hidden;
  }

  .player-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .player-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.1) 100%);
  }

  .player-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .player-badge {
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--white);
    background: #ef4444;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .player-channel {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--white);
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  .player-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.15);
  }

  .player-progress {
    height: 100%;
    width: 65%;
    background: var(--blue-500);
    border-radius: 2px;
  }

  .channel-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .channel-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    cursor: default;
  }

  .channel-logo {
    height: 28px;
    border-radius: 6px;
    overflow: hidden;
  }

  .channel-logo svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .channel-card span {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--gray-500);
  }

  /* Floating device badges */
  .float-float {
    position: absolute;
    inset: -30px;
    pointer-events: none;
  }

  .float-el {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 13px;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid var(--gray-200);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--gray-700);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    animation: float 5s ease-in-out infinite;
    white-space: nowrap;
  }

  .float-el svg {
    color: var(--blue-500);
  }

  .float-1 { top: -8px; right: 40px; animation-delay: 0s; }
  .float-2 { bottom: 24px; left: -28px; animation-delay: -1.6s; }
  .float-3 { bottom: -14px; right: 16px; animation-delay: -3.2s; }
  .float-4 { top: 36px; left: -18px; animation-delay: -0.8s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-text {
      max-width: 100%;
      text-align: center;
    }

    .hero-subtitle {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-ctas {
      justify-content: center;
    }

    .hero-trust {
      justify-content: center;
    }

    .hero-visual {
      max-width: 560px;
      margin: 0 auto;
    }

    .mockup-body {
      height: 250px;
    }
  }

  @media (max-width: 568px) {
    .hero {
      padding: 120px 0 60px;
      min-height: auto;
    }

    .mockup-body {
      grid-template-columns: 44px 1fr;
      height: 200px;
    }

    .mockup-sidebar {
      padding: 8px 4px;
    }

    .sidebar-item {
      padding: 4px 2px;
    }

    .sidebar-item svg {
      width: 12px;
      height: 12px;
    }

    .sidebar-item span {
      font-size: 0.45rem;
    }

    .channel-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .channel-logo {
      height: 24px;
    }

    .main-player {
      height: 72px;
      padding: 10px;
    }

    .player-channel {
      font-size: 0.7rem;
    }

    .float-el {
      display: none;
    }
