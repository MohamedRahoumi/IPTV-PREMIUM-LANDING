---
const partners = [
  { name: 'Sky Sports', color: '#1e293b' },
  { name: 'HBO', color: '#000000' },
  { name: 'Netflix', color: '#e50914' },
  { name: 'ESPN', color: '#d00' },
  { name: 'Premier League', color: '#37003c' },
  { name: 'DAZN', color: '#191919' },
  { name: 'Disney+', color: '#113cc3' },
  { name: 'Amazon Prime', color: '#00a8e1' },
  { name: 'BBC', color: '#b00100' },
  { name: 'Canal+', color: '#000' },
];
---

<section class="partners-section">
  <div class="container">
    <div class="partners-label reveal">Trusted by — 10,000+ active subscribers</div>
    <div class="partners-track reveal reveal-delay-1">
      <div class="partners-scroll">
        {[...partners, ...partners].map((p) => (
          <div class="partner-logo" style={`--brand: ${p.color};`}>
            <span>{p.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .partners-section {
    padding: 0 0 80px;
    margin-top: -20px;
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  .partners-label {
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
  }

  .partners-track {
    position: relative;
    width: 100%;
  }

  .partners-track::before,
  .partners-track::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .partners-track::before {
    left: 0;
    background: linear-gradient(90deg, var(--white) 0%, transparent 100%);
  }

  .partners-track::after {
    right: 0;
    background: linear-gradient(90deg, transparent 0%, var(--white) 100%);
  }

  .partners-scroll {
    display: flex;
    gap: 12px;
    animation: scrollLogos 30s linear infinite;
    width: max-content;
  }

  .partners-scroll:hover {
    animation-play-state: paused;
  }

  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    background: var(--white);
    border: 1px solid var(--gray-200);
    white-space: nowrap;
    transition: var(--transition);
  }

  .partner-logo span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gray-400);
    letter-spacing: -0.01em;
    transition: var(--transition);
  }

  .partner-logo:hover {
    border-color: var(--gray-300);
    box-shadow: var(--shadow-sm);
  }

  .partner-logo:hover span {
    color: var(--brand, var(--gray-900));
  }

  @keyframes scrollLogos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .partners-section {
      padding: 0 0 60px;
    }

    .partners-track::before,
    .partners-track::after {
      width: 40px;
    }

    .partner-logo {
      padding: 10px 20px;
    }

    .partner-logo span {
      font-size: 0.8rem;
    }
  }
</style>
