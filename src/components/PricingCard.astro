---
interface Props {
  name: string;
  price: number;
  features: string[];
  variant?: 'standard' | 'highlight';
  badge?: string;
  subtitle?: string;
}

const { name, price, features, variant = 'standard', badge, subtitle } = Astro.props;
---

<div class="pricing-card" data-variant={variant}>
  {badge && <div class="pricing-badge">{badge}</div>}
  <div class="pricing-top">
    <h3 class="pricing-name">{name}</h3>
    {subtitle && <p class="pricing-sub">{subtitle}</p>}
    <div class="pricing-amount">
      <span class="pricing-dollar">$</span>
      <span class="pricing-number">{price}</span>
      <span class="pricing-period">/year</span>
    </div>
  </div>
  <ul class="pricing-features">
    {features.map((f) => (
      <li class="pricing-feature">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>{f}</span>
      </li>
    ))}
  </ul>
  <div class="pricing-actions">
    <a href="#contact" class="btn-pricing-primary">
      Buy Now — ${price}
    </a>
  </div>
</div>

<style>
  .pricing-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 24px;
    padding: 0;
    position: relative;
    transition: all 0.35s ease;
    overflow: hidden;
  }

  .pricing-card:hover {
    box-shadow: 0 20px 48px -12px rgba(0,0,0,0.1);
    transform: translateY(-6px);
  }

  .pricing-card[data-variant="highlight"] {
    border: 2px solid var(--blue-500);
    box-shadow: 0 4px 24px rgba(37,99,235,0.1);
    background: linear-gradient(180deg, var(--white) 0%, rgba(37,99,235,0.02) 100%);
  }

  .pricing-card[data-variant="highlight"]:hover {
    box-shadow: 0 20px 48px -8px rgba(37,99,235,0.15);
  }

  .pricing-badge {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--blue-500);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 5px 18px;
    border-radius: 20px;
    z-index: 2;
    white-space: nowrap;
  }

  .pricing-top {
    padding: 36px 32px 8px;
    text-align: center;
  }

  .pricing-card[data-variant="highlight"] .pricing-top {
    padding-top: 52px;
  }

  .pricing-name {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--gray-900);
    margin-bottom: 2px;
  }

  .pricing-sub {
    font-size: 0.8rem;
    color: var(--gray-400);
    font-weight: 500;
  }

  .pricing-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 2px;
    margin-top: 20px;
    margin-bottom: 4px;
  }

  .pricing-dollar {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--gray-400);
  }

  .pricing-number {
    font-size: 3.4rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--gray-900);
  }

  .pricing-period {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-400);
  }

  .pricing-features {
    list-style: none;
    padding: 20px 32px 8px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.4;
  }

  .pricing-feature svg {
    color: var(--blue-500);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .pricing-actions {
    padding: 20px 32px 32px;
  }

  .btn-pricing-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 15px 24px;
    border-radius: 14px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: inherit;
    letter-spacing: -0.01em;
    text-decoration: none;
    background: var(--gray-900);
    color: var(--white);
    border: none;
  }

  .btn-pricing-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .pricing-card[data-variant="highlight"] .btn-pricing-primary {
    background: var(--blue-500);
    box-shadow: 0 4px 16px rgba(37,99,235,0.2);
  }

  .pricing-card[data-variant="highlight"] .btn-pricing-primary:hover {
    background: var(--blue-400);
    box-shadow: 0 8px 28px rgba(37,99,235,0.25);
  }

  @media (max-width: 768px) {
    .pricing-top {
      padding: 28px 24px 4px;
    }

    .pricing-card[data-variant="highlight"] .pricing-top {
      padding-top: 44px;
    }

    .pricing-features {
      padding: 16px 24px 4px;
    }

    .pricing-actions {
      padding: 16px 24px 24px;
    }

    .pricing-number {
      font-size: 2.8rem;
    }
  }
</style>
