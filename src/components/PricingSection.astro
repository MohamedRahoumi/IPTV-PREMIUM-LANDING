---
import PricingCard from './PricingCard.astro';

const eagleFeatures = [
  '20,000+ live TV channels worldwide',
  'Premium live football & sports coverage',
  'Latest movies & TV series on demand',
  'HD & 4K quality streaming',
  'Anti-freeze buffer technology',
  '24/7 customer support',
  'Smart TV, Phone, PC, MAG support',
  '1 year Hot Player activation included',
];

const strongFeatures = [
  '25,000+ live TV channels worldwide',
  'All premium sports & PPV events',
  '80,000+ VOD titles (movies & series)',
  '8K & 4K ultra HD streaming',
  'Ultra-stable servers, 99.9% uptime',
  'Priority 24/7 customer support',
  'Multi-device simultaneous connections',
  '1 year Hot Player activation included',
];
---

<section id="packages" class="pricing-section">
  <div class="container">
    <div class="pricing-head reveal">
      <span class="pricing-tag" data-i18n="pricing.simplePricing">Simple Pricing</span>
      <h2 class="pricing-title" data-i18n="pricing.title">Choose the plan that fits you</h2>
      <p class="pricing-desc" data-i18n="pricing.desc">
        Both plans include 1 year of Hot Player activation. No hidden fees. Cancel anytime.
      </p>
    </div>
    <div class="pricing-grid">
      <div class="reveal reveal-delay-1">
        <PricingCard
          name="Starter"
          price={25}
          features={eagleFeatures}
          subtitle="1 Year IPTV Subscription + Hot Player"
        />
      </div>
      <div class="reveal reveal-delay-2">
        <PricingCard
          name="Premium"
          price={40}
          features={strongFeatures}
          subtitle="1 Year IPTV Subscription + Hot Player"
          variant="highlight"
          badge="Most Popular"
        />
      </div>
    </div>
    <p class="pricing-footnote" data-i18n="pricing.footnote">All prices in USD. 14-day money-back guarantee on all plans.</p>
  </div>
</section>

<style>
  .pricing-section {
    padding: 100px 0;
    background: var(--gray-50);
    position: relative;
  }

  .pricing-head {
    text-align: center;
    margin-bottom: 52px;
  }

  .pricing-tag {
    display: inline-block;
    padding: 5px 16px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--blue-500);
    background: rgba(37,99,235,0.07);
    border: 1px solid rgba(37,99,235,0.12);
    margin-bottom: 18px;
  }

  .pricing-title {
    font-size: clamp(1.9rem, 3.4vw, 2.7rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--gray-900);
  }

  .pricing-desc {
    font-size: 1.05rem;
    color: var(--gray-500);
    margin-top: 12px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 820px;
    margin: 0 auto;
    align-items: start;
  }

  .pricing-footnote {
    text-align: center;
    font-size: 0.82rem;
    color: var(--gray-400);
    margin-top: 28px;
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: 64px 0;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
