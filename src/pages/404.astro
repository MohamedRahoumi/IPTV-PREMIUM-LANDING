---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found | IPTV Premium"
  description="The page you are looking for does not exist. Return to IPTV Premium homepage."
>
  <main style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:120px 24px;text-align:center;">
    <div>
      <div style="font-size:5rem;font-weight:800;letter-spacing:-0.06em;color:var(--blue-500);line-height:1;margin-bottom:8px;">404</div>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--gray-900);margin-bottom:10px;">Page not found</h1>
      <p style="font-size:1rem;color:var(--gray-500);margin-bottom:28px;max-width:380px;margin-left:auto;margin-right:auto;line-height:1.6;">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="btn btn-primary btn-lg" style="display:inline-flex;">Back to Homepage</a>
    </div>
  </main>
</BaseLayout>
