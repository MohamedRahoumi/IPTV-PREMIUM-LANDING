---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import Partners from '../components/Partners.astro';
import PricingSection from '../components/PricingSection.astro';
import Categories from '../components/Categories.astro';
import Features from '../components/Features.astro';
import LatestPosts from '../components/LatestPosts.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import StickyWhatsApp from '../components/StickyWhatsApp.astro';
---

<BaseLayout
  title="IPTV Premium — Starter & Premium | Premium IPTV Subscription"
  description="Get the best IPTV subscription with Starter ($25/yr) and Premium ($70/yr). Watch live sports, movies, TV channels, and series in 4K/8K. 24/7 support."
  keywords="IPTV, IPTV subscription, Starter plan, Premium plan, live football, premium IPTV, 4K streaming, 8K streaming, Hot Player"
  ogImage="https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?w=1200&q=80"
>
  <Nav />
  <main>
    <Hero />
    <TrustIndicators />
    <Partners />
    <PricingSection />
    <Categories />
    <Features />
    <LatestPosts />
    <Testimonials />
    <FAQ />
    <Contact />
  </main>
  <Footer />
  <StickyWhatsApp />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
